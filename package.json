{
  "version": "2.0.1",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/alexlafroscia/ember-runtime-config.git"
  },
  "license": "MIT",
  "author": "Alex LaFroscia",
  "scripts": {
    "build": "pnpm --filter=ember-runtime-config run build",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "prepare": "pnpm run build",
    "release": "release-it",
    "start": "concurrently 'pnpm:start:*' --restart-after 5000 --prefix-colors cyan,white,yellow",
    "start:addon": "pnpm --filter=ember-runtime-config run start",
    "start:test-app": "pnpm --filter=test-app run start",
    "test": "pnpm --filter=test-app run test",
    "test:ember": "pnpm --filter '*' test:ember"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@glint/core": "^1.5.0",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "prettier-plugin-ember-template-tag": "^2.1.3",
    "release-plan": "^0.17.0"
  },
  "packageManager": "pnpm@9.15.9",
  "volta": {
    "node": "22.22.0",
    "pnpm": "9.15.9"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowAny": [
        "ember-runtime-config",
        "ember-source",
        "typescript"
      ],
      "ignoreMissing": [
        "webpack"
      ]
    }
  }
}
